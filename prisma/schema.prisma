// SME ERP — schema core (P0-2): danh mục + hạ tầng.
// Model đơn hàng / hóa đơn / kho chi tiết sẽ thêm ở các phase sau (P1+).
// Nguyên tắc: 1 nguồn sự thật, tiền = Decimal(15,2), KHÔNG kế toán kép.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== RBAC / NGƯỜI DÙNG =====
model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  roleId       String?
  role         Role?     @relation(fields: [roleId], references: [id])
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([roleId])
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  users       User[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Permission {
  id          String           @id @default(cuid())
  code        String           @unique // vd: "product.create", "order.deliver"
  description String?
  roles       RolePermission[]
}

// Bảng nối Role <-> Permission (RBAC load từ DB mỗi request).
model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

// ===== DANH MỤC =====
model Product {
  id        String   @id @default(cuid())
  sku       String   @unique
  name      String
  unit      String
  buyPrice  Decimal  @default(0) @db.Decimal(15, 2) // giá nhập gần nhất (tham chiếu)
  sellPrice Decimal  @default(0) @db.Decimal(15, 2)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inventory WarehouseInventory[]
  movements InventoryMovement[]
}

model Customer {
  id          String   @id @default(cuid())
  name        String
  phone       String?
  email       String?
  creditLimit Decimal  @default(0) @db.Decimal(15, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Supplier {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Warehouse {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inventory WarehouseInventory[]
}

// Quỹ tiền mặt / ngân hàng. balance = NGUỒN SỰ THẬT số dư tiền.
model Account {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  balance   Decimal  @default(0) @db.Decimal(15, 2)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===== KHO =====
// Tồn theo lô. avgCost = giá vốn bình quân gia quyền (WAC) per unit.
model WarehouseInventory {
  id          String    @id @default(cuid())
  warehouseId String
  productId   String
  quantity    Int       @default(0)
  avgCost     Decimal   @default(0) @db.Decimal(15, 2)
  // Lệch Mục B (String?) có chủ đích: Postgres coi NULL là distinct trong unique,
  // nên null-batch KHÔNG chặn trùng → tìm-hoặc-tạo bị race. Dùng "" = "không lô".
  batchNumber String    @default("")
  expiryDate  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  product   Product   @relation(fields: [productId], references: [id])

  @@unique([warehouseId, productId, batchNumber])
  @@index([productId])
}

// Event table — nguồn COGS/tồn. Mỗi lần nhập/xuất ghi 1 dòng bất biến.
model InventoryMovement {
  id            String   @id @default(cuid())
  type          String // IN | OUT
  reason        String // PURCHASE_RECEIPT | SALES_SHIPMENT | RETURN_* | ADJUST_* | DROPSHIP_*
  productId     String
  warehouseId   String?
  quantity      Int
  unitCost      Decimal  @db.Decimal(15, 2)
  totalCost     Decimal  @db.Decimal(15, 2)
  referenceType String
  referenceId   String
  createdAt     DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([referenceType, referenceId])
  // Idempotent: 1 (reference, reason) chỉ sinh 1 movement.
  @@unique([referenceType, referenceId, reason])
}

// ===== HẠ TẦNG =====
// Outbox pattern cho side-effect bất đồng bộ (FOR UPDATE SKIP LOCKED + backoff).
model OutboxEvent {
  id             String    @id @default(cuid())
  type           String
  payload        Json
  status         String    @default("PENDING") // PENDING | PROCESSING | DONE | DEAD
  attempts       Int       @default(0)
  nextRetryAt    DateTime?
  lockedUntil    DateTime?
  idempotencyKey String?   @unique
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status, nextRetryAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  entityType String
  entityId   String
  userId     String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId])
}
