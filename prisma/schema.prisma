// SME ERP — schema core (P0-2): danh mục + hạ tầng.
// Model đơn hàng / hóa đơn / kho chi tiết sẽ thêm ở các phase sau (P1+).
// Nguyên tắc: 1 nguồn sự thật, tiền = Decimal(15,2), KHÔNG kế toán kép.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== RBAC / NGƯỜI DÙNG =====
model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  roleId       String?
  role         Role?     @relation(fields: [roleId], references: [id])
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([roleId])
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  users       User[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Permission {
  id          String           @id @default(cuid())
  code        String           @unique // vd: "product.create", "order.deliver"
  description String?
  roles       RolePermission[]
}

// Bảng nối Role <-> Permission (RBAC load từ DB mỗi request).
model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

// ===== DANH MỤC =====
model Product {
  id        String   @id @default(cuid())
  sku       String   @unique
  name      String
  unit      String
  buyPrice  Decimal  @default(0) @db.Decimal(15, 2) // giá nhập gần nhất (tham chiếu)
  sellPrice Decimal  @default(0) @db.Decimal(15, 2)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inventory      WarehouseInventory[]
  movements      InventoryMovement[]
  salesItems     SalesOrderItem[]
  purchaseItems  PurchaseOrderItem[]
}

model Customer {
  id          String   @id @default(cuid())
  name        String
  phone       String?
  email       String?
  creditLimit Decimal  @default(0) @db.Decimal(15, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  salesOrders SalesOrder[]
}

model Supplier {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchaseOrders PurchaseOrder[]
}

model Warehouse {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inventory   WarehouseInventory[]
  salesOrders SalesOrder[]
}

// Quỹ tiền mặt / ngân hàng. balance = NGUỒN SỰ THẬT số dư tiền.
model Account {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  balance   Decimal  @default(0) @db.Decimal(15, 2)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===== KHO =====
// Tồn theo lô. avgCost = giá vốn bình quân gia quyền (WAC) per unit.
model WarehouseInventory {
  id          String    @id @default(cuid())
  warehouseId String
  productId   String
  quantity    Int       @default(0)
  avgCost     Decimal   @default(0) @db.Decimal(15, 2)
  // Lệch Mục B (String?) có chủ đích: Postgres coi NULL là distinct trong unique,
  // nên null-batch KHÔNG chặn trùng → tìm-hoặc-tạo bị race. Dùng "" = "không lô".
  batchNumber String    @default("")
  expiryDate  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  product   Product   @relation(fields: [productId], references: [id])

  @@unique([warehouseId, productId, batchNumber])
  @@index([productId])
}

// Event table — nguồn COGS/tồn. Mỗi lần nhập/xuất ghi 1 dòng bất biến.
model InventoryMovement {
  id            String   @id @default(cuid())
  type          String // IN | OUT
  reason        String // PURCHASE_RECEIPT | SALES_SHIPMENT | RETURN_* | ADJUST_* | DROPSHIP_*
  productId     String
  warehouseId   String?
  quantity      Int
  unitCost      Decimal  @db.Decimal(15, 2)
  totalCost     Decimal  @db.Decimal(15, 2)
  referenceType String
  referenceId   String
  createdAt     DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([referenceType, referenceId])
  // Idempotent: 1 (reference, reason, product) chỉ sinh 1 movement.
  @@unique([referenceType, referenceId, reason, productId])
}

// ===== ĐƠN HÀNG =====
enum OrderStatus {
  PENDING
  DELIVERED
  CANCELLED
}

enum PurchaseStatus {
  ORDERED
  RECEIVED
  CANCELLED
}

enum FulfillmentType {
  WAREHOUSE
  DROPSHIP
}

// DERIVE từ Invoice — KHÔNG set tay từ client (nguồn sự thật = Invoice.balanceDue).
enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

model SalesOrder {
  id                    String          @id @default(cuid())
  orderCode             String          @unique
  status                OrderStatus     @default(PENDING)
  paymentStatus         PaymentStatus   @default(UNPAID) // DERIVE, không set tay
  fulfillmentType       FulfillmentType @default(WAREHOUSE)
  customerId            String
  warehouseId           String?
  linkedPurchaseOrderId String?         @unique // dropship (điền ở P2-2)
  salespersonId         String? // người bán → hoa hồng
  userId                String? // người tạo
  saleDate              DateTime?
  deliveredDate         DateTime?
  totalAmount           Decimal         @default(0) @db.Decimal(15, 2)
  taxAmount             Decimal         @default(0) @db.Decimal(15, 2)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  customer  Customer         @relation(fields: [customerId], references: [id])
  warehouse Warehouse?       @relation(fields: [warehouseId], references: [id])
  items     SalesOrderItem[]

  @@index([status])
  @@index([customerId, status])
}

model SalesOrderItem {
  id           String  @id @default(cuid())
  salesOrderId String
  productId    String?
  productName  String
  unit         String
  qty          Int
  sellPrice    Decimal @db.Decimal(15, 2) // đơn giá
  sellTotal    Decimal @db.Decimal(15, 2) // = sellPrice * qty (thành tiền dòng, chưa thuế)
  baseCost     Decimal @default(0) @db.Decimal(15, 2) // ĐƠN GIÁ vốn/unit (không lẫn tổng)
  profit       Decimal @default(0) @db.Decimal(15, 2) // chốt lúc giao — báo cáo lãi dùng field này
  taxAmount    Decimal @default(0) @db.Decimal(15, 2)

  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  product    Product?   @relation(fields: [productId], references: [id])

  @@index([salesOrderId])
}

model PurchaseOrder {
  id            String         @id @default(cuid())
  orderCode     String         @unique
  status        PurchaseStatus @default(ORDERED)
  paymentStatus PaymentStatus  @default(UNPAID) // DERIVE, không set tay
  supplierId    String
  warehouseId   String?
  userId        String?
  orderDate     DateTime?
  receivedDate  DateTime?
  totalAmount   Decimal        @default(0) @db.Decimal(15, 2)
  taxAmount     Decimal        @default(0) @db.Decimal(15, 2)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  supplier Supplier            @relation(fields: [supplierId], references: [id])
  items    PurchaseOrderItem[]

  @@index([status])
  @@index([supplierId, status])
}

model PurchaseOrderItem {
  id              String  @id @default(cuid())
  purchaseOrderId String
  productId       String?
  productName     String
  unit            String
  qty             Int
  buyPrice        Decimal @db.Decimal(15, 2) // đơn giá nhập
  buyTotal        Decimal @db.Decimal(15, 2) // = buyPrice * qty
  taxAmount       Decimal @default(0) @db.Decimal(15, 2)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product?      @relation(fields: [productId], references: [id])

  @@index([purchaseOrderId])
}

// Lịch sử chuyển trạng thái đơn (C4: updateStatus ghi history trước khi side-effect).
// referenceType = SALES_ORDER | PURCHASE_ORDER; fromStatus null = lúc tạo.
model OrderStatusHistory {
  id            String   @id @default(cuid())
  referenceType String
  referenceId   String
  fromStatus    String?
  toStatus      String
  userId        String?
  note          String?
  createdAt     DateTime @default(now())

  @@index([referenceType, referenceId])
}

// ===== HẠ TẦNG =====
// Outbox pattern cho side-effect bất đồng bộ (FOR UPDATE SKIP LOCKED + backoff).
model OutboxEvent {
  id             String    @id @default(cuid())
  type           String
  payload        Json
  status         String    @default("PENDING") // PENDING | PROCESSING | DONE | DEAD
  attempts       Int       @default(0)
  nextRetryAt    DateTime?
  lockedUntil    DateTime?
  idempotencyKey String?   @unique
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status, nextRetryAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  entityType String
  entityId   String
  userId     String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId])
}
